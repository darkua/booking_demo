# API (api/ or run from repo root with cd api)
PORT=3000
STATE_ROOT=../state
JWT_SECRET=change-me-in-production

ADMIN_USERNAME=altarise
ADMIN_PASSWORD=Password123!

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WEBHOOK_BASE_URL=https://your-subdomain.ngrok-free.app
TWILIO_APPOINTMENT_TEMPLATE_SID=

# Booking rules (API)
BOOKING_TIMEZONE=Europe/Berlin

# Verbose file path logging (API)
# DEBUG_STATE=true

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Max WhatsApp messages (in+out) sent to the model as conversation context
WHATSAPP_HISTORY_MAX_MESSAGES=80

# MCP HTTP bridge (optional; must match api)
MCP_API_KEY=dev-mcp-secret

# Vue (web/.env)
# VITE_API_URL=http://localhost:3000
# Same IANA zone as BOOKING_TIMEZONE so the dashboard columns match API booking windows
# VITE_BOOKING_TIMEZONE=Europe/Berlin
